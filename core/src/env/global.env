# shellcheck disable=all
# vim: fileencoding=utf-8:ft=sh

EDITOR=nvim
SSH_PROFILES=laradvil radvil radvil1
PROJECTS=/media/data/Projects/Personal
DOTFILES=$PROJECTS/dotfiles
NOTES_DIR=$HOME/Documents/Notes
STARSHIP_CONFIG=$DOTFILES/starship/src/starship.toml
PATH_EXTRA=$HOME/.local/bin $HOME/.spoofdpi/bin

# GAMING env
PROTON_ENABLE_WAYLAND=1
OBS_VKCAPTURE=0

# Disables window decorations using the Linux window manager.
# It can fix issues with borderless fullscreen and the mouse clicking through the window.
# See: https://wiki.cachyos.org/configuration/gaming/#proton-cachyos
# PROTON_NO_WM_DECORATION=1
